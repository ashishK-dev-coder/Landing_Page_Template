# PostgreSQL (runtime connection)
# - Local Postgres: use localhost:5432 (example below)
# - Supabase on Vercel: use Transaction Pooler URL (:6543) with sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/landing_page_template?schema=public"

# Direct PostgreSQL connection (used by Prisma for migrations/introspection)
# - Local Postgres: same as DATABASE_URL is fine
# - Supabase: use direct host db.<project-ref>.supabase.co:5432 with sslmode=require
DIRECT_URL="postgresql://user:password@localhost:5432/landing_page_template?schema=public"

# Platform domain — subdomains & custom domains
PLATFORM_DOMAIN="sites.youragency.com"
PLATFORM_ROOT_DOMAIN="youragency.com"

DEFAULT_GST_PERCENT="18"

# Team API (optional in local dev)
TEAM_API_KEY="your-secret-team-key"

# Visual editor — password only (change ADMIN_PASSWORD when needed)
ADMIN_PASSWORD="change-this-password"
SESSION_SECRET="replace-with-a-long-random-secret-min-32-chars"
